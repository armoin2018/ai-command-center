{
  "name": "ai-command-center",
  "displayName": "AI Command Center",
  "description": "Centralize AI-powered development workflows with integrated planning, instruction management, and external service integrations",
  "version": "0.1.0",
  "publisher": "ai-command-center",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Project Management",
    "Notebooks"
  ],
  "keywords": [
    "planning",
    "epic",
    "story",
    "task",
    "jira",
    "ai",
    "mcp"
  ],
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ai-command-center"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:aicc-planning-panel"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aicc.createEpic",
        "title": "AI Command Center: Create Epic"
      },
      {
        "command": "aicc.createStory",
        "title": "AI Command Center: Create Story"
      },
      {
        "command": "aicc.createTask",
        "title": "AI Command Center: Create Task"
      },
      {
        "command": "aicc.openPlanningPanel",
        "title": "AI Command Center: Open Planning Panel"
      },
      {
        "command": "aicc.exportToJira",
        "title": "AI Command Center: Export to Jira"
      },
      {
        "command": "aicc.config.validate",
        "title": "AI Command Center: Validate Configuration"
      },
      {
        "command": "aicc.config.showHealth",
        "title": "AI Command Center: Show Configuration Health"
      },
      {
        "command": "aicc.config.applyPreset",
        "title": "AI Command Center: Apply Configuration Preset"
      },
      {
        "command": "aicc.config.showRecommendations",
        "title": "AI Command Center: Show Configuration Recommendations"
      },
      {
        "command": "aicc.config.exportConfig",
        "title": "AI Command Center: Export Configuration"
      },
      {
        "command": "aicc.config.reload",
        "title": "AI Command Center: Reload Configuration"
      },
      {
        "command": "aicc.config.comparePresets",
        "title": "AI Command Center: Compare Configuration Presets"
      },
      {
        "command": "aicc.config.showVersion",
        "title": "AI Command Center: Show Configuration Version"
      }
    ],
    "configuration": {
      "title": "AI Command Center",
      "properties": {
        "aicc.planPath": {
          "type": "string",
          "default": ".project/plan",
          "description": "Directory path for planning artifacts (relative to workspace root)",
          "order": 1
        },
        "aicc.autoSaveInterval": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "Auto-save interval in seconds (0 = disabled)",
          "order": 2
        },
        "aicc.storyPointScale": {
          "type": "string",
          "default": "fibonacci",
          "enum": [
            "fibonacci",
            "linear"
          ],
          "enumDescriptions": [
            "Fibonacci scale: 1, 2, 3, 5, 8, 13, 21",
            "Linear scale: 1, 2, 3, 4, 5, 6, 7, 8"
          ],
          "description": "Story point estimation scale",
          "order": 3
        },
        "aicc.sprintDurationWeeks": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 4,
          "description": "Default sprint duration in weeks",
          "order": 4
        },
        "aicc.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "enumDescriptions": [
            "Debug: Verbose logging for development",
            "Info: General informational messages",
            "Warn: Warning messages only",
            "Error: Error messages only"
          ],
          "description": "Logging level for AI Command Center",
          "order": 10
        },
        "aicc.fileLoggingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable logging to file (in addition to Output Channel)",
          "order": 11
        },
        "aicc.retentionDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 30,
          "description": "Log file retention period in days",
          "order": 12
        },
        "aicc.maxFileSizeMB": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum log file size in MB before rotation",
          "order": 13
        },
        "aicc.jira.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Jira integration",
          "order": 20
        },
        "aicc.jira.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Jira Cloud base URL (e.g., https://your-domain.atlassian.net)",
          "order": 21
        },
        "aicc.jira.email": {
          "type": "string",
          "default": "",
          "description": "Jira account email for API authentication",
          "order": 22
        },
        "aicc.confluence.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Confluence integration",
          "order": 30
        },
        "aicc.confluence.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Confluence base URL (e.g., https://your-domain.atlassian.net/wiki)",
          "order": 31
        },
        "aicc.mcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP (Model Context Protocol) server",
          "order": 40
        },
        "aicc.mcp.protocol": {
          "type": "string",
          "default": "stdio",
          "enum": [
            "stdio",
            "http"
          ],
          "enumDescriptions": [
            "Standard I/O: For local AI agents",
            "HTTP: For remote AI agents"
          ],
          "description": "MCP server protocol",
          "order": 41
        },
        "aicc.ui.showWelcomeMessage": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome message on extension activation",
          "order": 50
        },
        "aicc.ui.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "light",
            "dark",
            "auto"
          ],
          "enumDescriptions": [
            "Light theme",
            "Dark theme",
            "Auto: Match VS Code theme"
          ],
          "description": "UI theme for planning panel",
          "order": 51
        },
        "aicc.ui.confirmDelete": {
          "type": "boolean",
          "default": true,
          "description": "Confirm destructive actions (delete epic/story/task)",
          "order": 52
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && cd webview && npm run build",
    "compile:webview": "cd webview && npm run build",
    "watch": "tsc -watch -p ./",
    "watch:webview": "cd webview && npm run watch",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.2",
    "js-yaml": "^4.1.1",
    "winston": "^3.19.0",
    "ws": "^8.19.0"
  }
}
