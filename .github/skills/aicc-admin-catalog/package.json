{
  "name": "aicc-admin-catalog",
  "version": "1.0.0",
  "description": "Manage AI Kit catalogs with installation, configuration, updates, and evolution",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "catalog": "node --loader ts-node/esm scripts/index.ts",
    "list": "npm run catalog list",
    "install": "npm run catalog install",
    "update": "npm run catalog update",
    "remove": "npm run catalog remove",
    "configure": "npm run catalog configure",
    "evolve": "npm run catalog evolve",
    "build": "tsc",
    "dev": "tsx watch scripts/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ai-kit",
    "catalog",
    "package-manager",
    "git",
    "automation"
  ],
  "author": "AI-ley Team",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.12.0",
    "axios": "^1.6.7",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
