# Zoom API Configuration

# Required: Zoom API Client ID
# Get from: https://marketplace.zoom.us/develop/create
# Format: Your JWT App Client ID
ZOOM_CLIENT_ID=your_client_id_here

# Required: Zoom API Client Secret
# Get from: https://marketplace.zoom.us/develop/create
# Format: Your JWT App Client Secret
ZOOM_CLIENT_SECRET=your_client_secret_here

# Required: Zoom Account ID (for OAuth flow)
# Get from: Zoom Account Settings → Advanced
# Format: Your Account/Workspace ID
ZOOM_ACCOUNT_ID=your_account_id_here

# Optional: Default user email (for testing)
ZOOM_USER_EMAIL=

# Optional: Webhook secret (for receiving events)
ZOOM_WEBHOOK_SECRET=

# Optional: API request timeout (milliseconds)
ZOOM_TIMEOUT=30000

# Optional: Rate limit (requests per second)
ZOOM_RATE_LIMIT=10

# Optional: Zoom subdomain (for custom/on-premises)
ZOOM_SUBDOMAIN=zoom.us

# Optional: Authentication type (jwt or oauth)
ZOOM_AUTH_TYPE=jwt
