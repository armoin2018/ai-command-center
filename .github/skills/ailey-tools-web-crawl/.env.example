# Crawl Configuration
START_URL=https://example.com
OUTPUT_DIR=./crawled

# Crawl Depth & Limits
MAX_DEPTH=3
MAX_PAGES=1000
MAX_DURATION_MINUTES=60
MAX_FILE_SIZE_MB=100

# Cross-Site Crawling
ALLOW_CROSS_SITE=false
ALLOWED_DOMAINS=example.com,sub.example.com

# Parallelization
MAX_CONCURRENT=5
REQUEST_DELAY_MS=1000
RETRY_ATTEMPTS=3

# Filter Patterns (comma-separated)
INCLUDE_PATTERNS=/docs/**,/blog/**,/api/**
EXCLUDE_PATTERNS=/admin/**,/login/**,*.pdf

# File Type Filters (comma-separated)
ALLOWED_FILE_TYPES=html,htm,pdf,doc,docx,txt,md
DOWNLOAD_BINARIES=false
BINARY_EXTENSIONS=jpg,jpeg,png,gif,svg,webp,ico

# Browser Configuration
HEADLESS=true
USER_AGENT=Mozilla/5.0 (compatible; AIleyBot/1.0)
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
JAVASCRIPT_ENABLED=true
WAIT_UNTIL=networkidle2

# Authentication
AUTH_TYPE=none
# Options: none, basic, bearer, form, cookie
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_TOKEN=
AUTH_LOGIN_URL=
AUTH_USERNAME_FIELD=username
AUTH_PASSWORD_FIELD=password
AUTH_SUBMIT_SELECTOR=button[type="submit"]

# Cookies (JSON format)
COOKIES=[]
# Example: [{"name":"session","value":"abc123","domain":".example.com"}]

# Headers (JSON format)
CUSTOM_HEADERS={}
# Example: {"X-API-Key":"your-key","Accept":"application/json"}

# Proxy Configuration
PROXY_ENABLED=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Rate Limiting
RESPECT_ROBOTS_TXT=true
CRAWL_DELAY=1000
MAX_REQUESTS_PER_SECOND=2

# Output Configuration
SAVE_HTML=true
SAVE_METADATA=true
SAVE_SCREENSHOTS=false
COMPRESS_OUTPUT=false

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/crawler.log
VERBOSE=false
