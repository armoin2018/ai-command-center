# AI-ley Tools Model - Environment Configuration

# =======================
# Rendering Configuration
# =======================

# Enable API-based rendering (optional)
ENABLE_API_RENDERING=false

# Mermaid.ink API (for Mermaid rendering)
# Free tier: Unlimited requests (rate limited)
# No authentication required
MERMAID_INK_URL=https://mermaid.ink

# PlantUML Server API (for PlantUML rendering)
# Public server: https://www.plantuml.com/plantuml
# Self-hosted: http://localhost:8080
PLANTUML_SERVER_URL=https://www.plantuml.com/plantuml

# Rendering format (svg, png, pdf)
DEFAULT_RENDER_FORMAT=svg

# =======================
# Generator Configuration
# =======================

# Default diagram type (flowchart, sequence, class, er, gantt, state, pie, mindmap, timeline, sankey)
DEFAULT_DIAGRAM_TYPE=flowchart

# Default theme (default, dark, forest, neutral)
DEFAULT_THEME=default

# Enable natural language processing for diagram generation
ENABLE_NLP_GENERATION=true

# =======================
# Converter Configuration
# =======================

# Default conversion direction (mermaid-to-plantuml, plantuml-to-mermaid, auto)
DEFAULT_CONVERSION_DIRECTION=auto

# Preserve comments during conversion
PRESERVE_COMMENTS=true

# Preserve formatting during conversion
PRESERVE_FORMATTING=true

# =======================
# Parser Configuration
# =======================

# Enable syntax validation
ENABLE_SYNTAX_VALIDATION=true

# Enable complexity analysis
ENABLE_COMPLEXITY_ANALYSIS=true

# Maximum diagram complexity (nodes/edges)
MAX_DIAGRAM_COMPLEXITY=1000

# =======================
# Template Configuration
# =======================

# Template library directory
TEMPLATE_DIRECTORY=./templates

# Enable custom templates
ENABLE_CUSTOM_TEMPLATES=true

# =======================
# Batch Processing
# =======================

# Batch processing concurrency
BATCH_CONCURRENCY=5

# Batch processing timeout (ms)
BATCH_TIMEOUT=30000

# =======================
# Output Configuration
# =======================

# Output directory for generated diagrams
OUTPUT_DIRECTORY=./output

# Output file naming pattern ({name}, {type}, {format}, {timestamp})
OUTPUT_NAMING_PATTERN={name}.{format}

# Overwrite existing files
OVERWRITE_EXISTING=false

# =======================
# Logging Configuration
# =======================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Log file path
LOG_FILE=./logs/model.log

# Enable verbose output
VERBOSE=false

# =======================
# Cache Configuration
# =======================

# Enable caching for API requests
ENABLE_CACHE=true

# Cache TTL (seconds)
CACHE_TTL=3600

# Cache directory
CACHE_DIRECTORY=./.cache

# =======================
# Network Configuration
# =======================

# API request timeout (ms)
API_TIMEOUT=10000

# Maximum retries for failed API requests
MAX_RETRIES=3

# Retry delay (ms)
RETRY_DELAY=1000

# =======================
# VS Code Integration
# =======================

# Use VS Code's built-in Mermaid preview
USE_VSCODE_PREVIEW=true

# Open diagrams in VS Code after generation
OPEN_IN_VSCODE=false
