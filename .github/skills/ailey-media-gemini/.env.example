# Google AI Studio / Vertex AI Configuration
# Get your API key at: https://aistudio.google.com/app/apikey

# API Authentication
GEMINI_API_KEY=your_api_key_here

# For Vertex AI (Enterprise users)
GEMINI_PROJECT_ID=your_gcp_project_id
GEMINI_LOCATION=us-central1
GEMINI_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json

# Account Type (free, paid, enterprise)
GEMINI_ACCOUNT_TYPE=free

# API Settings
GEMINI_API_VERSION=v1
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com
GEMINI_TIMEOUT=120000

# Default Generation Settings
GEMINI_DEFAULT_MODEL=imagen-3.0-generate-001
GEMINI_DEFAULT_VIDEO_MODEL=veo-2.0-generate-001
GEMINI_DEFAULT_ASPECT_RATIO=1:1
GEMINI_DEFAULT_NEGATIVE_PROMPT=

# Output Settings
GEMINI_OUTPUT_DIR=./output
GEMINI_OUTPUT_FORMAT=png
GEMINI_SAVE_METADATA=true

# Rate Limiting (requests per minute)
GEMINI_RATE_LIMIT_FREE=15
GEMINI_RATE_LIMIT_PAID=60
GEMINI_RATE_LIMIT_ENTERPRISE=300

# Feature Flags
GEMINI_ENABLE_IMAGEN=true
GEMINI_ENABLE_VEO=true
GEMINI_ENABLE_UPSCALING=true
GEMINI_ENABLE_EDITING=true

# Cache Settings
GEMINI_CACHE_ENABLED=true
GEMINI_CACHE_TTL=3600
GEMINI_CACHE_MAX_SIZE=100
GEMINI_CACHE_DIR=./cache

# Logging
GEMINI_VERBOSE_LOG=false
GEMINI_LOG_FILE=./logs/gemini.log
