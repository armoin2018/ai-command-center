# Vonage Communications API Configuration

# Required: Vonage API Key
# Get from: https://dashboard.vonage.com/
# Format: Your API Key from dashboard
VONAGE_API_KEY=your_api_key_here

# Required: Vonage API Secret
# Get from: https://dashboard.vonage.com/
# Format: Your API Secret from dashboard
VONAGE_API_SECRET=your_api_secret_here

# Required: Default Sender ID (for SMS)
# Can be: Phone number (1234567890) or alphanumeric (YourBrand)
VONAGE_SENDER_ID=YourBrand

# Optional: Application ID (for Voice API)
# Get from: Vonage Dashboard → Applications
VONAGE_APPLICATION_ID=

# Optional: Private Key Path (for JWT authentication)
# Path to your private key file for Voice API
VONAGE_PRIVATE_KEY_PATH=

# Optional: Vonage Business ID
# Get from: Account Settings
VONAGE_ACCOUNT_ID=

# Optional: Default recipient number (for testing)
VONAGE_DEFAULT_RECIPIENT=

# Optional: Webhook URL (for receiving messages and callbacks)
VONAGE_WEBHOOK_URL=

# Optional: API request timeout (milliseconds)
VONAGE_TIMEOUT=30000

# Optional: Rate limit (requests per second)
VONAGE_RATE_LIMIT=10

# Optional: Vonage subdomain (for custom endpoints)
VONAGE_SUBDOMAIN=api.vonage.com
