{
  "name": "ailey-tools-video",
  "version": "1.0.0",
  "description": "Comprehensive video processing toolkit for AI-ley - conversion, editing, captioning, manipulation, multi-file batch processing (arrays, globs), and streaming (HTTP/HTTPS, RTSP, RTMP, HLS, stdin/stdout)",
  "main": "scripts/index.ts",
  "scripts": {
    "video": "tsx scripts/index.ts",
