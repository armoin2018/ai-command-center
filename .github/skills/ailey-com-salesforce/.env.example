# Salesforce OAuth Configuration
# Create a Connected App in Salesforce Setup to get these credentials

# OAuth Credentials
SALESFORCE_CLIENT_ID=your_consumer_key_here
SALESFORCE_CLIENT_SECRET=your_consumer_secret_here
SALESFORCE_CALLBACK_URL=http://localhost:3000/oauth/callback

# Salesforce Instance
# Use login.salesforce.com for production or test.salesforce.com for sandbox
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Authentication Method
# Options: oauth (recommended), username-password (legacy), jwt (server-to-server)
AUTH_METHOD=oauth

# Username-Password Flow (Legacy - Not Recommended)
# Only use if OAuth is not available
SALESFORCE_USERNAME=your_email@example.com
SALESFORCE_PASSWORD=your_password_with_security_token
# Security token is appended to password: password + security_token

# JWT Bearer Flow (Server-to-Server)
# For automation and CI/CD environments
SALESFORCE_PRIVATE_KEY_PATH=./certs/server.key
SALESFORCE_USERNAME_JWT=integration@example.com

# API Version
# Salesforce API version (e.g., 59.0, 60.0)
SALESFORCE_API_VERSION=59.0

# Edition Detection
# Auto-detected on first connection, but can be overridden
# Options: Developer, Professional, Enterprise, Unlimited, Performance
SALESFORCE_EDITION=auto

# API Limits
# Adjust based on your Salesforce edition
# Developer: 15,000 API calls/24h
# Professional: 5,000 API calls/24h per license
# Enterprise: 100,000 API calls/24h
# Unlimited: Unlimited API calls
MAX_API_CALLS_PER_DAY=15000

# Bulk API Configuration
BULK_BATCH_SIZE=10000
BULK_CONCURRENCY=5
ENABLE_BULK_API=true

# Query Configuration
DEFAULT_QUERY_LIMIT=2000
ENABLE_QUERY_MORE=true

# Object Configuration
# Comma-separated list of custom objects to track
CUSTOM_OBJECTS=CustomObject__c,AnotherObject__c

# Standard Objects
STANDARD_OBJECTS=Account,Contact,Lead,Opportunity,Case,Task,Event

# Export Configuration
EXPORT_FORMAT=csv
EXPORT_DIRECTORY=./exports

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/salesforce.log
VERBOSE=false

# Cache Configuration
ENABLE_CACHE=true
CACHE_TTL=3600

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=1000

# Timeout Configuration
API_TIMEOUT=30000
BULK_TIMEOUT=300000

# Sandbox Mode
# Set to true if using a Salesforce sandbox
IS_SANDBOX=false
