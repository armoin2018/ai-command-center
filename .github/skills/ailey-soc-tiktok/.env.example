# Required for all tiers
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# OAuth redirect URI (must match app configuration)
TIKTOK_REDIRECT_URI=http://localhost:3000/auth/callback

# Access tokens (obtained via OAuth flow)
TIKTOK_ACCESS_TOKEN=your_access_token_here
TIKTOK_REFRESH_TOKEN=your_refresh_token_here

# Optional: API version (default: v2)
TIKTOK_API_VERSION=v2

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Create TikTok Developer Account
#    https://developers.tiktok.com/
#
# 2. Create App
#    - Go to: https://developers.tiktok.com/apps/
#    - Click "Create an app"
#    - Fill in app details
#    - Copy Client Key → TIKTOK_CLIENT_KEY
#    - Copy Client Secret → TIKTOK_CLIENT_SECRET
#
# 3. Configure OAuth
#    - In app dashboard → "Login Kit"
#    - Add redirect URI: http://localhost:3000/auth/callback
#    - Select scopes based on your tier:
#      * Tier 1: user.info.basic
#      * Tier 2: + video.list
#      * Tier 3: + video.upload, video.publish, comment.list
#      * Tier 4: + ad.management, campaign.create
#
# 4. Get Access Token (OAuth Flow)
#    - Run: npm run tiktok auth start
#    - Follow OAuth instructions
#    - Copy access_token → TIKTOK_ACCESS_TOKEN
#    - Copy refresh_token → TIKTOK_REFRESH_TOKEN
#
# 5. Test Configuration
#    npm run tiktok detect
#    npm run tiktok test
#
# ============================================================================
# API TIER INFORMATION
# ============================================================================
#
# Your available features depend on your TikTok API tier:
#
# Tier 1 (Login Kit) - Auto-approved:
#   ✅ OAuth authentication
#   ✅ Basic user profile
#   ❌ Video uploads
#   ❌ Analytics
#
# Tier 2 (Display API) - Application required (1-2 weeks):
#   ✅ All Tier 1 features
#   ✅ List videos
#   ✅ Video information
#   ❌ Video uploads
#   ❌ Analytics
#
# Tier 3 (Content Posting API) - Manual approval (2-8 weeks):
#   ✅ All Tier 1-2 features
#   ✅ Video uploads
#   ✅ Video analytics
#   ✅ Comment management
#   ✅ Audience insights
#
# Tier 4 (Marketing API) - Partner status (3-6 months):
#   ✅ All Tier 1-3 features
#   ✅ Campaign management
#   ✅ Ad creation
#   ✅ Marketing analytics
#
# Run "npm run tiktok detect" to check your current tier.
# Run "npm run tiktok setup" for detailed tier upgrade instructions.
#
