# WhatsApp Business API Configuration

# Required: API Access Token
# Get from: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# Format: Your Bearer token from Cloud Dashboard
WHATSAPP_API_TOKEN=your_api_token_here

# Required: Business Phone Number ID
# Get from: WhatsApp Cloud Dashboard → Phone Numbers
# Format: Numeric ID of your business phone number
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Required: Business Account ID (WABA ID)
# Get from: WhatsApp Cloud Dashboard → Settings
# Format: Numeric ID of your business account
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# Optional: Default recipient phone number (for testing)
WHATSAPP_DEFAULT_RECIPIENT=

# Optional: Webhook verification token
# Generate: Any secure random string
WHATSAPP_WEBHOOK_TOKEN=

# Optional: API request timeout (milliseconds)
WHATSAPP_TIMEOUT=30000

# Optional: Rate limit (messages per minute)
WHATSAPP_RATE_LIMIT=60

# Optional: Webhook URL (for receiving messages)
WHATSAPP_WEBHOOK_URL=

# Optional: Environment (cloud or on-premises)
WHATSAPP_ENVIRONMENT=cloud
