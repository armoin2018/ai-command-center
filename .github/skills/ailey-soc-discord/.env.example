# ============================================================================
# DISCORD BOT CONFIGURATION
# ============================================================================

# Required: Bot authentication from Discord Developer Portal
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# ============================================================================
# PRIVILEGED GATEWAY INTENTS
# ============================================================================
#
# Set to 'true' to enable. You must ALSO enable these in the Discord
# Developer Portal (Bot tab → Privileged Gateway Intents).
#
# ⚠️  IMPORTANT: If your bot is in 75+ servers, you MUST verify your bot
#    before privileged intents will work.
#
# See setup guide: npm run discord setup
#
# ============================================================================

# SERVER MEMBERS INTENT (GUILD_MEMBERS)
# Allows: Track member joins/leaves, access member list
# Use for: Welcome messages, member tracking, member analytics
# Verification: Required if 75+ servers
DISCORD_INTENT_MEMBERS=false

# PRESENCE INTENT (GUILD_PRESENCES)
# Allows: See member status (online/idle/dnd) and activities (playing/streaming)
# Use for: Activity tracking, status-based features, analytics
# Verification: Required if 75+ servers
DISCORD_INTENT_PRESENCES=false

# MESSAGE CONTENT INTENT (MESSAGE_CONTENT)
# Allows: Read actual message content (text)
# Use for: Content moderation, spam filtering, command parsing
# Verification: Required if 75+ servers
# ⚠️  Note: Slash commands work WITHOUT this intent
DISCORD_INTENT_MESSAGE_CONTENT=false

# ============================================================================
# STANDARD INTENTS (ALWAYS ENABLED)
# ============================================================================
#
# These intents are always available and don't require special permissions:
#   • GUILDS - Server events (join, leave, create channels)
#   • GUILD_MESSAGES - Message events (but not content without MESSAGE_CONTENT)
#   • GUILD_MESSAGE_REACTIONS - Reaction events
#   • GUILD_VOICE_STATES - Voice state changes
#   • DIRECT_MESSAGES - DM events
#
# ============================================================================

# ============================================================================
# HOW TO GET VALUES
# ============================================================================
#
# DISCORD_BOT_TOKEN:
#   1. Go to https://discord.com/developers/applications
#   2. Select your application
#   3. Go to "Bot" tab
#   4. Under "Token", click "Reset Token"
#   5. Copy token (keep it secret!)
#
# DISCORD_CLIENT_ID:
#   1. Go to https://discord.com/developers/applications
#   2. Select your application
#   3. Go to "General Information" tab
#   4. Copy "APPLICATION ID"
#
# ============================================================================

# ============================================================================
# INTENT LEVELS
# ============================================================================
#
# Based on which privileged intents you enable, your bot has different
# capability levels:
#
# Basic Bot (all false):
#   • Send messages, slash commands, voice channels
#   • Manage roles, channels
#   • ❌ Cannot read message content
#   • ❌ Cannot track members
#
# + GUILD_MEMBERS:
#   • All basic features
#   • Track member joins/leaves
#   • Access member list
#
# + GUILD_PRESENCES:
#   • All basic features
#   • See member status (online/idle/dnd)
#   • Track activities (playing, streaming)
#
# + MESSAGE_CONTENT:
#   • All basic features
#   • Read message content
#   • Content moderation
#   • Auto-moderation
#
# All Privileged (all true):
#   • All features enabled
#   • Full bot capabilities
#
# ⚠️  Bots in 75+ servers with privileged intents MUST be verified.
#    See: npm run discord setup
#
# ============================================================================

# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# 🔐 NEVER commit .env to git!
#    Add .env to .gitignore
#
# 🔐 NEVER share your bot token!
#    If compromised, reset in Developer Portal immediately
#
# 🔐 Use environment variables in production:
#    Do not hardcode tokens in source code
#
# ============================================================================

# ============================================================================
# QUICK START
# ============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in DISCORD_BOT_TOKEN and DISCORD_CLIENT_ID
#
# 3. Test connection:
#    npm run discord test
#
# 4. Detect intents:
#    npm run discord detect
#
# 5. Register slash commands:
#    npm run discord register-commands
#
# 6. Enable privileged intents as needed:
#    - Update this file (set to 'true')
#    - Enable in Developer Portal
#    - Restart bot
#
# For detailed setup: npm run discord setup
#
# ============================================================================
