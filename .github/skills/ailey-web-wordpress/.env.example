# WordPress.com and Self-Hosted WordPress Configuration

# ==============================================================================
# WordPress.com OAuth (Recommended for WordPress.com sites)
# ==============================================================================

# OAuth Application ID (from developer.wordpress.com)
WORDPRESS_COM_CLIENT_ID=your_client_id_here

# OAuth Application Secret (from developer.wordpress.com)
WORDPRESS_COM_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect URI (must match registered URI)
WORDPRESS_COM_REDIRECT_URI=http://localhost:3000/callback

# ==============================================================================
# Self-Hosted WordPress (For self-hosted or custom domains)
# ==============================================================================

# Your WordPress Site URL (without trailing slash)
# Example: https://example.com or https://blog.example.com
WORDPRESS_SITE_URL=https://example.com

# WordPress Application Password (from wp-admin → Users → Profile)
# Generate at: /wp-admin/user-edit.php?user_id=1 (Admin User)
WORDPRESS_APP_USERNAME=admin

# Application Password (generated in WordPress)
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ==============================================================================
# Account Settings
# ==============================================================================

# WordPress.com Site ID (auto-detected if blank)
# Format: numeric site ID from wordpress.com
WORDPRESS_SITE_ID=

# Default Post Type (post or page)
WORDPRESS_DEFAULT_POST_TYPE=post

# Default Post Status (publish, draft, pending, private, scheduled)
WORDPRESS_DEFAULT_POST_STATUS=draft

# ==============================================================================
# Optional: Advanced Settings
# ==============================================================================

# API Timeout (milliseconds)
WORDPRESS_TIMEOUT=30000

# Number of retries for failed requests
WORDPRESS_RETRIES=3

# Cache timeout for site info (seconds)
WORDPRESS_CACHE_TTL=3600

# Verbose logging (true/false)
WORDPRESS_VERBOSE=false

# ==============================================================================
# Optional: SEO and Analytics
# ==============================================================================

# Jetpack API Token (for analytics and SEO features)
WORDPRESS_JETPACK_TOKEN=

# Yoast SEO API Key (if using Yoast)
WORDPRESS_YOAST_API_KEY=

# Google Analytics ID (if connected)
WORDPRESS_GOOGLE_ANALYTICS_ID=
