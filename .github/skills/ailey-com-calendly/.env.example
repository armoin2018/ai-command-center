# Calendly API Configuration
#
# Copy this file to one of these locations:
#   - ~/.vscode/.env (global, shared across all projects)
#   - <workspace-root>/.env (project-specific)
#   - <workspace-root>/.env.local (local overrides, git-ignored)
#
# Choose ONE authentication method:

# Method 1: Personal Access Token (for internal/team use)
CALENDLY_ACCESS_TOKEN=your-personal-access-token-here

# Method 2: OAuth 2.0 (for public apps with multiple users)
CALENDLY_CLIENT_ID=your-oauth-client-id
CALENDLY_CLIENT_SECRET=your-oauth-client-secret
CALENDLY_REDIRECT_URI=http://localhost:3000/callback

# Optional: Specify user URI for scoped operations
# Format: https://api.calendly.com/users/{uuid}
CALENDLY_USER_URI=

# API Configuration
CALENDLY_API_URL=https://api.calendly.com
CALENDLY_AUTH_URL=https://auth.calendly.com

# Subscription Tier (auto-detected if not set)
# Options: basic, essentials, professional, teams, enterprise
# CALENDLY_TIER=professional

# Webhook Configuration (requires Premium+ subscription)
CALENDLY_WEBHOOK_SIGNING_KEY=your-webhook-signing-key
