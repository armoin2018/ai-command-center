# Mailchimp Integration Environment Variables
# Copy this to .env and fill in your values

# Required: Mailchimp API Key
# Get from: https://mailchimp.com/account/ → Extras → API Keys
# Format: key-us1
MAILCHIMP_API_KEY=

# Required: Server Prefix
# Extracted from API key suffix (us1, us2, eu1, ca1, etc.)
MAILCHIMP_SERVER_PREFIX=us1

# Optional: Default List ID for operations
MAILCHIMP_LIST_ID=

# Optional: Request timeout in milliseconds
MAILCHIMP_TIMEOUT=10000

# Optional: Rate limit (requests per minute)
MAILCHIMP_RATE_LIMIT=10

# Optional: Logging level (debug, info, warn, error)
LOG_LEVEL=info
