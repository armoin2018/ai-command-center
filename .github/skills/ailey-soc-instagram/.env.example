# Example .env file for Instagram Integration
# Copy this to .env and fill in your credentials

# Required: Instagram API Credentials
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# Optional: API Configuration
INSTAGRAM_API_VERSION=v18.0

# Optional: Facebook Page ID (for reference)
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# Optional: Debugging
DEBUG=instagram:*

# =============================================================================
# HOW TO GET THESE VALUES:
# =============================================================================
#
# 1. INSTAGRAM_ACCESS_TOKEN
#    - Go to https://developers.facebook.com/tools/explorer/
#    - Select your app
#    - Click "Generate Access Token"
#    - Grant permissions: instagram_basic, instagram_content_publish,
#      instagram_manage_comments, instagram_manage_insights,
#      pages_read_engagement, pages_show_list
#    - Copy the token
#    - For long-lived token (60 days), exchange via OAuth
#    - For never-expiring token, use Page Access Token
#
# 2. INSTAGRAM_ACCOUNT_ID
#    - Run: npm run instagram auth get-account-id --page-id YOUR_PAGE_ID
#    - Or use Graph API Explorer:
#      GET /{page-id}?fields=instagram_business_account
#    - Copy the ID from instagram_business_account object
#
# 3. INSTAGRAM_API_VERSION (optional)
#    - Current stable version: v18.0
#    - Update to latest version periodically
#    - See: https://developers.facebook.com/docs/graph-api/changelog
#
# 4. FACEBOOK_PAGE_ID (optional)
#    - Your Facebook Page ID
#    - Used for reference and account lookup
#    - Find at: facebook.com/your-page > About section
#
# =============================================================================
# SETUP INSTRUCTIONS:
# =============================================================================
#
# Run: npm run instagram setup
#
# For detailed setup guide, see SETUP.md
#
# =============================================================================
