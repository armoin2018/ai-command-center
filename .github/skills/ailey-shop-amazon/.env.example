# Amazon Selling Partner API Configuration

# API Credentials (from https://sellercentral.amazon.com/)
AMAZON_CLIENT_ID=your_lwa_client_id
AMAZON_CLIENT_SECRET=your_lwa_client_secret
AMAZON_REFRESH_TOKEN=your_refresh_token
AMAZON_ACCESS_KEY_ID=your_aws_access_key_id
AMAZON_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Seller Information
AMAZON_SELLER_ID=your_seller_id
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_ACCOUNT_TYPE=professional

# Region Configuration
AMAZON_REGION=us-east-1
AMAZON_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# Optional Configuration
AMAZON_API_VERSION=2021-06-30
AMAZON_TIMEOUT=30000
AMAZON_VERBOSE_LOG=false

# Feature Toggles
AMAZON_FEATURES_PRODUCTS=true
AMAZON_FEATURES_ORDERS=true
AMAZON_FEATURES_INVENTORY=true
AMAZON_FEATURES_PRICING=true
AMAZON_FEATURES_ADVERTISING=true
AMAZON_FEATURES_REVIEWS=true

# Cache Configuration
AMAZON_CACHE_TTL=3600
AMAZON_CACHE_MAX_ITEMS=1000
AMAZON_CACHE_STORAGE_PATH=./amazon_cache
