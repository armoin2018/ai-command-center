# Etsy API Configuration

# API Credentials (from https://www.etsy.com/developers)
ETSY_API_KEY=your_api_key_here
ETSY_API_SECRET=your_api_secret_here
ETSY_ACCESS_TOKEN=your_access_token_here
ETSY_SHOP_ID=your_shop_id_here

# Account Information
ETSY_ACCOUNT_TYPE=business
ETSY_USER_ID=your_user_id_here

# Optional Configuration
ETSY_API_VERSION=v3
ETSY_API_TIMEOUT=30000
ETSY_VERBOSE_LOG=false

# Feature Toggles
ETSY_FEATURES_SHOP=true
ETSY_FEATURES_LISTINGS=true
ETSY_FEATURES_ORDERS=true
ETSY_FEATURES_REVIEWS=true
ETSY_FEATURES_ANALYTICS=true
ETSY_FEATURES_FAVORITES=true

# Cache Configuration
ETSY_CACHE_TTL=3600
ETSY_CACHE_MAX_ITEMS=1000
ETSY_CACHE_STORAGE_PATH=./etsy_cache
