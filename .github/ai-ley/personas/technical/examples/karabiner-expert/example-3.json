{
  "description": "Remap keys only in VS Code",
  "manipulators": [
    {
      "type": "basic",
      "from": { "key_code": "j", "modifiers": { "mandatory": ["control"] } },
      "to": [{ "key_code": "down_arrow" }],
      "conditions": [
        {
          "type": "frontmost_application_if",
          "bundle_identifiers": ["^com\\.microsoft\\.VSCode$"]
        }
      ]
    }
  ]
}