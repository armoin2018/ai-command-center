{
  "spec": ["test/**/*.test.js", "test/**/*.spec.js"],
  "exclude": ["test/fixtures/**", "test/helpers/**"],
  "require": ["test/setup.js"],
  "reporter": "spec",
  "timeout": 5000,
  "recursive": true,
  "exit": true,
  "bail": false,
  "grep": "",
  "invert": false,
  "checkLeaks": true,
  "globals": ["expect"],
  "colors": true,
  "growl": false,
  "asyncOnly": false,
  "delay": false,
  "forbidOnly": false,
  "forbidPending": false,
  "fullTrace": false,
  "retries": 0,
  "slow": 75,
  "ui": "bdd"
}