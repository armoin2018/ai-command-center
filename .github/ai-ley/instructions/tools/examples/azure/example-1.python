                    },
                    {
                        "name": "Data Exfiltration Detection",
                        "description": "Identifies potential data exfiltration activities",
                        "severity": "High",
                        "query_frequency": "PT10M",
                        "query_period": "PT2H",
                        "tactics": ["Exfiltration"],
                        "techniques": ["T1041", "T1048"]
                    }
                ],
                "playbooks": [
