                    "load_balancer_efficiency": True
                },
                "reserved_instances": {
                    "analysis_enabled": True,
                    "minimum_usage_threshold": 70,
                    "commitment_terms": ["1 year", "3 years"],
                    "resource_types": [
                        "Microsoft.Compute/virtualMachines",
