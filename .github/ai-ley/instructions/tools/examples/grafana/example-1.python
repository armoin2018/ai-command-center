                        'gridPos': {"h": 8, "w": 24, "x": 0, "y": 0}
                    },
                    {
                        'title': 'Incident Response Time',
                        'type': 'graph',
                        'targets': [{
                            'expr': 'avg(incident_response_time_seconds)',
