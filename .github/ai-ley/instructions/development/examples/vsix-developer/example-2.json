{
  "contributes": {
    "menus": {
      "editor/context": [{
        "command": "extension.myCommand",
        "when": "editorTextFocus",
        "group": "navigation"
      }],
      "view/title": [{
        "command": "extension.refresh",
        "when": "view == myView",
        "group": "navigation"
      }],
      "commandPalette": [{
        "command": "extension.myCommand",
        "when": "editorHasSelection"
      }]
    }
  }
}