{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-command-center.github.io/schemas/structure.v1.schema.json",
  "title": "AI Kit Structure Schema",
  "description": "Schema for AI Kit structure configuration files",
  "type": "object",
  "required": ["name", "repo", "branch", "folderMapping"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference",
      "x-hidden": true
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the structure schema",
      "default": "1.0.0",
      "x-readonly": true
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 1,
      "maxLength": 100,
      "description": "Unique kit identifier (lowercase, alphanumeric, hyphens only)",
      "x-readonly": true,
      "x-ui-order": 1
    },
    "repo": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://github\\.com/[^/]+/[^/]+(\\.git)?$",
      "description": "GitHub repository URL",
      "x-readonly": true,
      "x-ui-order": 2
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Git branch to use for this kit",
      "x-ui-order": 3
    },
    "refreshEnabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable automatic refresh based on refreshInterval",
      "x-ui-order": 10,
      "x-ui-group": "refresh"
    },
    "refreshInterval": {
      "type": ["string", "number"],
      "pattern": "^\\d+$",
      "minimum": 0,
      "description": "Refresh interval in seconds (string or number)",
      "x-ui-order": 11,
      "x-ui-group": "refresh"
    },
    "evolveEnabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable contribution back to source repository",
      "x-ui-order": 20,
      "x-ui-group": "evolution"
    },
    "icon": {
      "type": "string",
      "description": "Path to icon file (relative to kit root)",
      "x-readonly": true
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief description of the kit",
      "x-ui-order": 4
    },
    "author": {
      "type": "string",
      "description": "Kit author or organization",
      "x-readonly": true
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last install or update",
      "x-hidden": true
    },
    "folderMapping": {
      "oneOf": [
        {
          "$ref": "#/definitions/folderMappingObject"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/folderMappingObject"
          },
          "minItems": 1
        }
      ],
      "description": "Folder mapping configuration (single object or array)",
      "x-hidden": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "uniqueItems": true,
      "description": "List of kit names this kit depends on",
      "x-readonly": true
    },
    "bundles": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/bundleObject"
      },
      "description": "Optional bundles of grouped assets that can be enabled/disabled together"
    },
    "configuration": {
      "$ref": "#/definitions/configurationObject",
      "description": "Kit configuration with form fields and automated actions"
    }
  },
  "definitions": {
    "folderMappingObject": {
      "type": "object",
      "required": ["source", "target", "type"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Source path in the kit repository"
        },
        "target": {
          "type": "string",
          "description": "Target path in the workspace"
        },
        "type": {
          "type": "string",
          "enum": ["folder", "file", "pattern"],
          "description": "Type of mapping: folder (entire directory), file (single file), pattern (glob pattern)"
        },
        "pattern": {
          "type": "string",
          "description": "Glob pattern for file matching (e.g., '**/*.md', '*.ts')"
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Glob patterns to exclude from mapping"
        },
        "rename": {
          "type": "object",
          "description": "Rename rules for files",
          "properties": {
            "pattern": {
              "type": "string",
              "description": "Regex pattern to match in filename"
            },
            "replacement": {
              "type": "string",
              "description": "Replacement string (supports $1, $2, etc. for capture groups)"
            }
          },
          "required": ["pattern", "replacement"]
        },
        "recursionDepth": {
          "type": "number",
          "minimum": 0,
          "default": -1,
          "description": "Maximum directory depth (-1 for unlimited)"
        },
        "evolveEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable evolution for this mapping"
        },
        "forceReplace": {
          "type": "boolean",
          "default": false,
          "description": "Force replace existing files"
        },
        "supportedAgentic": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["*"],
              "description": "Support all agentic systems"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "copilot",
                  "claude",
                  "cursor",
                  "windsurf",
                  "codex",
                  "gemini",
                  "custom",
                  "*"
                ]
              },
              "uniqueItems": true,
              "description": "List of supported agentic systems"
            }
          ],
          "description": "Agentic systems this mapping supports"
        },
        "preserveStructure": {
          "type": "boolean",
          "default": true,
          "description": "Preserve directory structure when copying"
        },
        "flattenStructure": {
          "type": "boolean",
          "default": false,
          "description": "Flatten directory structure (copy all files to target root)"
        }
      },
      "additionalProperties": false
    },
    "bundleObject": {
      "type": "object",
      "required": ["name", "enabled", "assets"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "minLength": 1,
          "maxLength": 100,
          "description": "Unique bundle identifier (lowercase, alphanumeric, hyphens)"
        },
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether the bundle is enabled by default"
        },
        "description": {
          "type": "string",
          "maxLength": 500,
          "description": "Brief description of what this bundle provides"
        },
        "icon": {
          "type": "string",
          "description": "Codicon icon name for visual representation"
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Paths to assets included in this bundle (e.g., 'skills/ailey-soc-discord', 'personas/marketing/social-media-expert.md')"
        }
      },
      "additionalProperties": false
    },
    "configurationObject": {
      "type": "object",
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/configFieldObject"
          },
          "description": "Configuration form fields rendered in the Configuration tab"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/configActionObject"
          },
          "description": "Automated actions triggered by conditions"
        }
      },
      "additionalProperties": false
    },
    "configFieldObject": {
      "type": "object",
      "required": ["name", "label", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Field identifier used as the form input name"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label displayed above the input"
        },
        "type": {
          "type": "string",
          "enum": ["text", "textarea", "select", "number", "checkbox", "toggle", "date", "email", "url", "radio"],
          "description": "Input type determining the rendered control"
        },
        "placeholder": {
          "type": "string",
          "description": "Placeholder text shown inside the input. Supports mustache templates (e.g., {{name}})"
        },
        "validation": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean", "default": false },
            "minLength": { "type": "integer", "minimum": 0 },
            "maxLength": { "type": "integer", "minimum": 0 },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "pattern": { "type": "string", "description": "Regex pattern for validation" },
            "errorMessage": { "type": "string", "description": "Custom error message on validation failure" }
          },
          "additionalProperties": false,
          "description": "Validation constraints for the field"
        },
        "helpText": {
          "type": "string",
          "description": "Help text displayed below the input"
        },
        "value": {
          "description": "Default value for the field. Supports mustache templates (e.g., {{branch}})"
        },
        "defaultValue": {
          "description": "Alias for value — default value for the field"
        },
        "options": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["label", "value"],
                "properties": {
                  "label": { "type": "string" },
                  "value": { "type": "string" }
                },
                "additionalProperties": false
              }
            ]
          },
          "description": "Options for select and radio field types"
        }
      },
      "additionalProperties": false
    },
    "configActionObject": {
      "type": "object",
      "required": ["actionType", "command"],
      "properties": {
        "actionType": {
          "type": "string",
          "enum": ["create", "edit", "delete", "bulk-edit", "bulk-delete", "sync", "import", "export"],
          "description": "Action type from the common AICC action library"
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/conditionObject"
          },
          "description": "All conditions must be met for the action to be available"
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "description": "Command to execute. Supports mustache-style field references (e.g., {{name}}, {{branch}})"
        },
        "label": {
          "type": "string",
          "description": "Optional display label for the action button"
        },
        "icon": {
          "type": "string",
          "description": "Optional codicon icon name for the action button"
        },
        "confirmMessage": {
          "type": "string",
          "description": "Optional confirmation prompt before execution. Supports mustache templates"
        }
      },
      "additionalProperties": false
    },
    "conditionObject": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "properties": {
        "field": {
          "type": "string",
          "description": "Field name or dot-path to evaluate (e.g., 'refreshEnabled', 'branch')"
        },
        "operator": {
          "type": "string",
          "enum": [
            "equals",
            "not-equals",
            "contains",
            "not-contains",
            "starts-with",
            "ends-with",
            "greater-than",
            "less-than",
            "greater-than-or-equals",
            "less-than-or-equals",
            "matches",
            "exists",
            "not-exists",
            "in",
            "not-in",
            "is-empty",
            "is-not-empty"
          ],
          "description": "Comparison operator for the condition"
        },
        "value": {
          "description": "Value to compare against. Type depends on the operator"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
