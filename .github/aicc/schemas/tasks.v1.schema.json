{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-command-center.dev/schemas/tasks.v1.schema.json",
  "title": "Task Scheduler Schema v1",
  "description": "Schema for per-workspace scheduled task configuration at .my/aicc/tasks.json",
  "type": "object",
  "required": ["version", "tasks"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the tasks format"
    },
    "tasks": {
      "type": "array",
      "description": "Array of scheduled task definitions",
      "items": {
        "type": "object",
        "required": ["id", "name", "enabled", "schedule", "actions"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique task identifier"
          },
          "name": {
            "type": "string",
            "description": "Human-readable task name"
          },
          "description": {
            "type": "string",
            "description": "Optional description of what the task does"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the task is actively scheduled"
          },
          "schedule": {
            "type": "object",
            "description": "Scheduling configuration",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["interval", "cron", "specific-time"],
                "description": "Type of schedule"
              },
              "intervalUnit": {
                "type": "string",
                "enum": ["seconds", "minutes", "hours", "days"],
                "description": "Unit for interval-based scheduling"
              },
              "intervalValue": {
                "type": "integer",
                "minimum": 1,
                "description": "Number of interval units between executions"
              },
              "cronExpression": {
                "type": "string",
                "description": "Cron expression for cron-based scheduling"
              },
              "specificTime": {
                "type": "string",
                "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
                "description": "Specific time of day in 24h HH:MM format"
              },
              "daysOfWeek": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
                },
                "description": "Days of the week the task should run"
              },
              "startTime": {
                "type": "string",
                "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
                "description": "Earliest time of day the task can run"
              },
              "endTime": {
                "type": "string",
                "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
                "description": "Latest time of day the task can run"
              }
            }
          },
          "actions": {
            "type": "array",
            "description": "Ordered list of actions to execute",
            "items": {
              "type": "object",
              "required": ["actionId", "command"],
              "properties": {
                "actionId": {
                  "type": "string",
                  "description": "Reference to unified action ID"
                },
                "command": {
                  "type": "string",
                  "description": "Command to execute"
                },
                "args": {
                  "type": "object",
                  "description": "Arguments to pass to the command"
                },
                "order": {
                  "type": "integer",
                  "description": "Execution order within the task"
                }
              }
            }
          },
          "lastRun": {
            "type": "object",
            "description": "Information about the most recent execution",
            "properties": {
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "When the task last ran"
              },
              "status": {
                "type": "string",
                "enum": ["success", "failure", "partial", "skipped", "killed"],
                "description": "Outcome of the last run"
              },
              "durationMs": {
                "type": "integer",
                "description": "Duration of the last run in milliseconds"
              },
              "errors": {
                "type": "array",
                "maxItems": 10,
                "description": "Rolling error history, capped at 10 entries (oldest rolled off). Cleared on successful execution.",
                "items": {
                  "type": "object",
                  "properties": {
                    "actionId": { "type": "string" },
                    "message": { "type": "string" },
                    "stack": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the task was created"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the task was last modified"
          },
          "killTimeoutEnabled": {
            "type": "boolean",
            "default": false,
            "description": "Whether to forcibly terminate the task after killTimeoutSeconds"
          },
          "killTimeoutSeconds": {
            "type": "integer",
            "minimum": 10,
            "default": 300,
            "description": "Seconds after which a running task is forcibly terminated"
          },
          "preventOverlap": {
            "type": "boolean",
            "default": true,
            "description": "Whether to skip a scheduled run if the previous run is still executing"
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "description": "Global scheduler settings",
      "properties": {
        "maxConcurrentTasks": {
          "type": "integer",
          "minimum": 1,
          "default": 3,
          "description": "Maximum number of tasks executing simultaneously"
        },
        "rateLimitPerMinute": {
          "type": "integer",
          "minimum": 1,
          "default": 30,
          "description": "Maximum task executions per minute across all tasks"
        },
        "stuckThresholdSeconds": {
          "type": "integer",
          "minimum": 30,
          "default": 600,
          "description": "Seconds after which a task is considered stuck and user is notified"
        }
      }
    }
  }
}
