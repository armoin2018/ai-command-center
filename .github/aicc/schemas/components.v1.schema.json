{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-command-center.github.io/schemas/components.v1.schema.json",
  "title": "AI Kit Components Schema",
  "description": "Schema for AI Kit component bundle configuration",
  "type": "object",
  "patternProperties": {
    "^[a-zA-Z0-9-_]+$": {
      "$ref": "#/definitions/component"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "component": {
      "type": "object",
      "required": ["defaultEnabled", "files"],
      "properties": {
        "defaultEnabled": {
          "type": "boolean",
          "description": "Whether this component is enabled by default on install",
          "default": true
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "File path relative to kit root"
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "List of files included in this component"
        },
        "description": {
          "type": "string",
          "maxLength": 200,
          "description": "Brief description of the component's purpose"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9-_]+$"
          },
          "uniqueItems": true,
          "description": "Other components this component depends on"
        },
        "category": {
          "type": "string",
          "enum": ["core", "optional", "experimental", "deprecated"],
          "default": "optional",
          "description": "Component category"
        },
        "supportedAgentic": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["copilot", "claude", "cursor", "windsurf", "codex", "gemini", "custom", "*"]
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["copilot", "claude", "cursor", "windsurf", "codex", "gemini", "custom", "*"]
              },
              "uniqueItems": true
            }
          ],
          "description": "Agentic systems this component supports"
        }
      }
    }
  }
}
