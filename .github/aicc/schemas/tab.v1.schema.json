{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-command-center.dev/schemas/tab.schema.json",
  "title": "AICC Tab Schema",
  "description": "Schema definition for AI Command Center UI tabs (views)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^v[0-9]+(alpha|beta)?[0-9]*$",
      "default": "v1"
    },
    "kind": {
      "type": "string",
      "const": "Tab",
      "description": "Resource type identifier"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "id"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable tab name"
        },
        "id": {
          "type": "string",
          "description": "Unique tab identifier",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "default": "1.0.0"
        },
        "icon": {
          "type": "string",
          "description": "Codicon name"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["components"],
      "properties": {
        "components": {
          "type": "array",
          "description": "Ordered list of components to render",
          "items": {
            "$ref": "#/definitions/ComponentReference"
          }
        },
        "layout": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["stack", "grid", "flex"],
              "default": "stack"
            },
            "direction": {
              "type": "string",
              "enum": ["column", "row"],
              "default": "column"
            },
            "gap": {
              "type": "string",
              "default": "12px"
            },
            "padding": {
              "type": "string",
              "default": "12px"
            }
          }
        },
        "dataBindings": {
          "type": "object",
          "description": "Tab-level data bindings",
          "additionalProperties": {
            "$ref": "#/definitions/DataBinding"
          }
        },
        "state": {
          "type": "object",
          "description": "Tab state management configuration",
          "properties": {
            "persist": {
              "type": "boolean",
              "description": "Persist state across sessions",
              "default": false
            },
            "initialState": {
              "type": "object",
              "description": "Initial state values",
              "additionalProperties": true
            }
          }
        },
        "hooks": {
          "type": "object",
          "description": "Lifecycle hooks",
          "properties": {
            "onMount": {
              "type": "string",
              "description": "JavaScript function to run on mount"
            },
            "onUnmount": {
              "type": "string",
              "description": "JavaScript function to run on unmount"
            },
            "onDataChange": {
              "type": "string",
              "description": "JavaScript function to run when data changes"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "ComponentReference": {
      "type": "object",
      "required": ["componentId"],
      "properties": {
        "componentId": {
          "type": "string",
          "description": "Reference to registered component (e.g., 'status-badges', 'accordion-list')"
        },
        "id": {
          "type": "string",
          "description": "Unique instance ID for this component"
        },
        "props": {
          "type": "object",
          "description": "Component properties",
          "additionalProperties": true
        },
        "dataBinding": {
          "type": "string",
          "description": "Reference to data binding key"
        },
        "condition": {
          "type": "string",
          "description": "Condition for showing component"
        },
        "order": {
          "type": "integer",
          "description": "Display order",
          "default": 0
        },
        "style": {
          "type": "object",
          "description": "Component-specific CSS overrides",
          "properties": {
            "className": {
              "type": "string"
            },
            "cssVariables": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "DataBinding": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["rest", "graphql", "sdk", "command", "state"],
          "description": "Data source type"
        },
        "endpoint": {
          "type": "string",
          "description": "API endpoint or command"
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "default": "GET"
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "transform": {
          "type": "string",
          "description": "Data transformation function"
        },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "ttl": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
