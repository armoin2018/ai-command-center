    }
  },
  "scripts": {
    "compile": "npm run compile:extension && npm run compile:webview && npm run copy:assets",
    "compile:extension": "webpack --mode production --config webpack.extension.config.js",
    "compile:extension:dev": "webpack --mode development --config webpack.extension.config.js",
    "compile:webview": "cd webview && npm run build",
    "copy:defaults": "mkdir -p dist/defaults && cp src/defaults/aicc.yaml dist/defaults/ 2>/dev/null || true",
    "copy:schemas": "mkdir -p dist/.github/aicc/schemas && cp -r .github/aicc/schemas/*.json dist/.github/aicc/schemas/ 2>/dev/null || true",
    "copy:swagger": "mkdir -p dist/swagger-ui && cp -r node_modules/swagger-ui-dist/*.{js,css,map,json,png} dist/swagger-ui/ 2>/dev/null || true",
    "copy:codicons": "mkdir -p dist/codicons && cp node_modules/@vscode/codicons/dist/codicon.css node_modules/@vscode/codicons/dist/codicon.ttf dist/codicons/ 2>/dev/null || true && cp node_modules/@vscode/codicons/dist/codicon.ttf media/secondaryPanel/codicon.ttf 2>/dev/null || true && sed '/@font-face/,/^}/d' node_modules/@vscode/codicons/dist/codicon.css > media/secondaryPanel/codicon.css 2>/dev/null || true",
    "copy:assets": "npm run copy:defaults && npm run copy:schemas && npm run copy:swagger && npm run copy:codicons",
    "watch": "webpack --watch --mode development --config webpack.extension.config.js",
    "watch:webview": "cd webview && npm run watch",
    "pretest": "npm run compile",
    "test": "node ./dist/test/runTest.js",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@types/winston": "^2.4.4",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@vscode/codicons": "^0.0.44",
    "axios": "^1.6.5",
    "js-yaml": "^4.1.1",
    "swagger-ui-dist": "^5.11.0",
    "winston": "^3.19.0",
    "ws": "^8.16.0"
  }
