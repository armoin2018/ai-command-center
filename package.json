        },
        "aicc.mcp.host": {
          "type": "string",
          "default": "localhost",
          "description": "Hostname or IP address to bind MCP server (requires aicc.mcp.localhostOnly to be false for non-localhost)",
          "order": 54
        },
        "aicc.mcp.portRangeStart": {
          "type": "number",
          "default": 3100,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Start of port range for multi-workspace MCP leader election",
          "order": 55
        },
        "aicc.mcp.portRangeEnd": {
          "type": "number",
          "default": 3110,
          "minimum": 1024,
          "maximum": 65535,
          "description": "End of port range for multi-workspace MCP leader election",
          "order": 56
        },
        "aicc.mcp.websocket.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable WebSocket transport for real-time bidirectional communication",
          "order": 57
        },
        "aicc.mcp.websocket.port": {
          "type": "number",
          "default": 3001,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port number for WebSocket server (only used when transport is 'websocket')",
          "order": 56
        },
        "aicc.ui.showWelcomeMessage": {
          "type": "boolean",
