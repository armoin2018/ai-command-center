    "chatParticipants": [
      {
        "id": "aicc.agent",
        "fullName": "AI Command Center Agent",
        "name": "aicc",
        "description": "AI Command Center planning and instruction management agent",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aicc-sidebar",
          "title": "AI Command Center Sidebar",
          "icon": "$(project)"
        }
      ],
      "panel": [
        {
          "id": "aicc-panel",
          "title": "AI Command Center Panel",
          "icon": "$(layers)"
        }
      ]
    },
    "views": {
      "aicc-sidebar": [
        {
          "id": "aicc.planningTreeView",
          "name": "Planning",
          "icon": "$(list-tree)",
          "contextualTitle": "AI Command Center Planning"
        }
      ],
      "aicc-panel": [
        {
          "id": "aicc.secondaryPanel",
          "type": "webview",
          "name": "Planning Panel",
          "icon": "$(layers)",
          "contextualTitle": "AI Command Center Panel",
          "visibility": "visible"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "aicc.planningTreeView",
        "contents": "Welcome to AI Command Center!\n\nCreate your first Epic to get started with planning.\n[Create Epic](command:aicc.createEpic)\n\nOr open the full planning panel:\n[Open Planning Panel](command:aicc.openPlanningPanel)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aicc.createEpic",
          "when": "view == aicc.planningTreeView",
          "group": "navigation@1"
        },
        {
          "command": "aicc.openPlanningPanel",
          "when": "view == aicc.planningTreeView",
          "group": "navigation@2"
        },
        {
          "command": "aicc.planning.refresh",
          "when": "view == aicc.planningTreeView",
          "group": "navigation@3"
        },
        {
          "command": "aicc.config.showHealth",
          "when": "view == aicc.planningTreeView",
          "group": "1_actions@1"
        },
        {
          "command": "aicc.runSyntheticTests",
          "when": "view == aicc.planningTreeView",
          "group": "1_actions@2"
        }
      ],
      "view/item/context": [
        {
          "command": "aicc.planning.edit",
          "when": "view == aicc.planningTreeView && viewItem =~ /epic|story|task/",
          "group": "1_edit@1"
        },
        {
          "command": "aicc.planning.delete",
          "when": "view == aicc.planningTreeView && viewItem =~ /epic|story|task/",
          "group": "1_edit@2"
        },
        {
          "submenu": "aicc.planning.changeStatus",
          "when": "view == aicc.planningTreeView && viewItem =~ /epic|story|task/",
          "group": "2_status@1"
        },
        {
          "command": "aicc.createStory",
          "when": "view == aicc.planningTreeView && viewItem == epic",
          "group": "3_create@1"
        },
        {
          "command": "aicc.createTask",
          "when": "view == aicc.planningTreeView && viewItem == story",
          "group": "3_create@1"
        },
        {
          "command": "aicc.planning.copyId",
          "when": "view == aicc.planningTreeView && viewItem =~ /epic|story|task/",
          "group": "4_clipboard@1"
        },
        {
          "command": "aicc.planning.copyAsMarkdown",
          "when": "view == aicc.planningTreeView && viewItem =~ /epic|story|task/",
          "group": "4_clipboard@2"
        }
      ],
      "aicc.planning.changeStatus": [
        {
          "command": "aicc.planning.setStatusNotStarted",
          "group": "status@1"
        },
        {
          "command": "aicc.planning.setStatusInProgress",
          "group": "status@2"
        },
        {
          "command": "aicc.planning.setStatusDone",
          "group": "status@3"
        }
      ]
    },
    "submenus": [
      {
        "id": "aicc.planning.changeStatus",
        "label": "Change Status"
      }
    ],
    "keybindings": [],
    "configuration": {
      "title": "AI Command Center",
      "properties": {
        "aicc.advancedMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable advanced mode to show legacy sidebar tree view, editor panel, and additional commands. When disabled (default), only the bottom panel UI is active.",
          "order": 0
        },
        "aicc.planPath": {
          "type": "string",
          "default": ".project/plan",
          "description": "Directory path for planning artifacts (relative to workspace root)",
          "order": 1
        },
        "aicc.idPrefix": {
          "type": "string",
          "default": "ARMOIN",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,19}$",
          "description": "Prefix for planning item IDs (e.g., 'ARMOIN' produces ARMOIN-001). Must start with a letter and contain only letters, digits, hyphens, or underscores (max 20 chars).",
          "order": 1
        },
        "aicc.autoSaveInterval": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "Auto-save interval in seconds (0 = disabled)",
          "order": 2
        },
        "aicc.storyPointScale": {
          "type": "string",
          "default": "fibonacci",
          "enum": [
            "fibonacci",
            "linear"
          ],
          "enumDescriptions": [
            "Fibonacci scale: 1, 2, 3, 5, 8, 13, 21",
            "Linear scale: 1, 2, 3, 4, 5, 6, 7, 8"
          ],
          "description": "Story point estimation scale",
          "order": 3
        },
        "aicc.sprintDurationWeeks": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 4,
          "description": "Default sprint duration in weeks",
          "order": 4
        },
        "aicc.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "enumDescriptions": [
            "Debug: Verbose logging for development",
            "Info: General informational messages",
            "Warn: Warning messages only",
            "Error: Error messages only"
          ],
          "description": "Logging level for AI Command Center",
          "order": 10
        },
        "aicc.fileLoggingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable logging to file (in addition to Output Channel)",
          "order": 11
        },
        "aicc.retentionDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 30,
          "description": "Log file retention period in days",
          "order": 12
        },
        "aicc.maxFileSizeMB": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum log file size in MB before rotation",
          "order": 13
        },
        "aicc.jira.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Jira integration",
          "order": 20
        },
        "aicc.jira.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Jira Cloud base URL (e.g., https://your-domain.atlassian.net)",
          "order": 21
        },
        "aicc.jira.email": {
          "type": "string",
          "default": "",
          "description": "Jira account email for API authentication",
          "order": 22
        },
        "aicc.jira.apiToken": {
          "type": "string",
          "default": "",
          "description": "Jira API token for authentication (stored securely)",
          "order": 23
        },
        "aicc.jira.projectKey": {
          "type": "string",
          "default": "",
          "description": "Default Jira project key (e.g., PROJ)",
          "order": 24
        },
        "aicc.jira.syncStrategy": {
          "type": "string",
          "default": "bidirectional",
          "enum": [
            "push",
            "pull",
            "bidirectional"
          ],
          "enumDescriptions": [
            "Push: Only push local changes to Jira",
            "Pull: Only pull Jira changes to local",
            "Bidirectional: Sync both ways with conflict detection"
          ],
          "description": "Jira synchronization strategy",
          "order": 25
        },
        "aicc.jira.conflictResolution": {
          "type": "string",
          "default": "manual",
          "enum": [
            "local-wins",
            "remote-wins",
            "manual",
            "merge"
          ],
          "enumDescriptions": [
            "Local Wins: Always keep local changes",
            "Remote Wins: Always keep Jira changes",
            "Manual: Prompt user to resolve conflicts",
            "Merge: Attempt automatic merge"
          ],
          "description": "Conflict resolution strategy",
          "order": 26
        },
        "aicc.jira.autoSync": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic synchronization with Jira",
          "order": 27
        },
        "aicc.jira.syncInterval": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 120,
          "description": "Auto-sync interval in minutes (only when autoSync is enabled)",
          "order": 28
        },
        "aicc.jira.webhookEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Jira webhook for real-time updates",
          "order": 29
        },
        "aicc.confluence.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Confluence integration",
          "order": 30
        },
        "aicc.confluence.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Confluence base URL (e.g., https://your-domain.atlassian.net/wiki)",
          "order": 31
        },
        "aicc.mcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP (Model Context Protocol) server",
          "order": 40
        },
        "aicc.mcp.transport": {
          "type": "string",
          "default": "stdio",
          "enum": [
            "stdio",
            "http",
            "https",
            "websocket"
          ],
          "enumDescriptions": [
            "Standard I/O: For local AI agents (Claude Desktop, etc.)",
            "HTTP: For remote AI agents and web-based connections (unencrypted)",
            "HTTPS: For remote AI agents with SSL/TLS encryption",
            "WebSocket: For real-time bidirectional communication"
          ],
          "description": "MCP server transport protocol",
          "order": 41
        },
        "aicc.mcp.port": {
          "type": "number",
          "default": 3000,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port number for HTTP transport (only used when transport is 'http')",
          "order": 42
        },
        "aicc.mcp.logging.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP server logging",
          "order": 43
        },
        "aicc.mcp.logging.level": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "enumDescriptions": [
            "Debug: Verbose MCP server logging",
            "Info: General MCP informational messages",
            "Warn: MCP warning messages only",
            "Error: MCP error messages only"
          ],
          "description": "MCP server log level",
          "order": 44
        },
        "aicc.mcp.tools.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP tools (create, update, delete, search operations)",
          "order": 45
        },
        "aicc.mcp.tools.timeout": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "Tool execution timeout in milliseconds",
          "order": 46
        },
        "aicc.mcp.resources.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP resources (planning tree, epic details, etc.)",
          "order": 47
        },
        "aicc.mcp.resources.cacheSize": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 1000,
          "description": "Number of resources to cache for faster access",
