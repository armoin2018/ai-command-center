{
  "version": "0.1.0",
  "tools": [
    {
      "name": "ailey-tools-data-converter",
      "displayName": "Data Format Converter",
      "description": "Convert files between data formats (JSON, YAML, XML, CSV, TSV, Parquet, Avro, ORC, Thrift) with compression and streaming support",
      "modelDescription": "Convert data files between multiple formats including JSON, YAML, XML, CSV, TSV, and binary formats like Parquet, Avro, ORC, and Thrift. Supports compression (gzip, brotli, zstd), streaming for large files, chunking, and URL input. Use when converting data formats, processing large files, transforming API responses, or batch converting multiple files.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["convert", "batch-convert", "stream-convert"],
            "description": "Conversion action to perform"
          },
          "input": {
            "type": "string",
            "description": "Input file path or URL"
          },
          "output": {
            "type": "string",
            "description": "Output file path"
          },
          "inputFormat": {
            "type": "string",
            "enum": ["json", "yaml", "xml", "csv", "tsv", "parquet", "avro", "orc", "thrift"],
            "description": "Input data format"
          },
          "outputFormat": {
            "type": "string",
            "enum": ["json", "yaml", "xml", "csv", "tsv", "parquet", "avro", "orc", "thrift"],
            "description": "Output data format"
          },
          "compression": {
            "type": "string",
            "enum": ["none", "gzip", "brotli", "zstd"],
            "default": "none",
            "description": "Compression algorithm"
          },
          "streaming": {
            "type": "boolean",
            "default": false,
            "description": "Use streaming for large files"
          },
          "chunkSize": {
            "type": "number",
            "description": "Chunk size for streaming (in bytes)"
          }
        },
        "required": ["action", "input", "output", "inputFormat", "outputFormat"]
      }
    }
  ]
}
