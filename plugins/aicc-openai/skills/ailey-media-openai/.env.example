# OpenAI API Configuration
# Get your API key at: https://platform.openai.com/api-keys

# API Authentication
OPENAI_API_KEY=sk-proj-...your_api_key_here
OPENAI_ORG_ID=org-...your_organization_id

# Account Type (trial, pay-as-you-go, enterprise)
OPENAI_ACCOUNT_TYPE=pay-as-you-go

# API Settings
OPENAI_API_VERSION=v1
OPENAI_ENDPOINT=https://api.openai.com
OPENAI_TIMEOUT=300000

# Default Generation Settings
OPENAI_DEFAULT_IMAGE_MODEL=dall-e-3
OPENAI_DEFAULT_VIDEO_MODEL=sora-1.0
OPENAI_DEFAULT_SIZE=1024x1024
OPENAI_DEFAULT_QUALITY=standard
OPENAI_DEFAULT_STYLE=vivid

# Output Settings
OPENAI_OUTPUT_DIR=./output
OPENAI_OUTPUT_FORMAT=png
OPENAI_SAVE_METADATA=true

# Rate Limiting (requests per minute)
OPENAI_RATE_LIMIT_TRIAL=3
OPENAI_RATE_LIMIT_TIER_1=5
OPENAI_RATE_LIMIT_TIER_2=7
OPENAI_RATE_LIMIT_TIER_3=7
OPENAI_RATE_LIMIT_TIER_4=15
OPENAI_RATE_LIMIT_TIER_5=50

# Feature Flags
OPENAI_ENABLE_DALLE=true
OPENAI_ENABLE_SORA=true
OPENAI_ENABLE_EDITING=true
OPENAI_ENABLE_VARIATIONS=true

# Cache Settings
OPENAI_CACHE_ENABLED=true
OPENAI_CACHE_TTL=3600
OPENAI_CACHE_MAX_SIZE=100
OPENAI_CACHE_DIR=./cache

# Logging
OPENAI_VERBOSE_LOG=false
OPENAI_LOG_FILE=./logs/openai.log
