# Canva API Configuration
#
# Copy this file to one of these locations:
#   - ~/.vscode/.env (global, shared across all projects)
#   - <workspace-root>/.env (project-specific)
#   - <workspace-root>/.env.local (local overrides, git-ignored)
#
# Authentication method: OAuth 2.0

# Canva OAuth 2.0 Credentials
CANVA_CLIENT_ID=your_client_id
CANVA_CLIENT_SECRET=your_client_secret
CANVA_REDIRECT_URI=http://localhost:3000/callback

# Access Token (obtained after OAuth flow)
CANVA_ACCESS_TOKEN=

# Refresh Token (for token renewal)
CANVA_REFRESH_TOKEN=

# API Configuration
CANVA_API_URL=https://api.canva.com/rest/v1
CANVA_AUTH_URL=https://www.canva.com/api/oauth

# Account Tier (auto-detected if not set)
# Options: free, pro, teams, enterprise
CANVA_TIER=

# Brand ID (for brand kit operations)
CANVA_BRAND_ID=

# Team ID (for team operations)
CANVA_TEAM_ID=
