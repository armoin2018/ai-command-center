# YouTube API Configuration
# Get these from: https://console.cloud.google.com/

# OAuth Credentials
YOUTUBE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_ACCESS_TOKEN=your_access_token_here
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Optional: API Key for some read-only operations
YOUTUBE_API_KEY=your_api_key_here

# Quota Management
YOUTUBE_QUOTA_MONITORING=true
YOUTUBE_QUOTA_WARNING_THRESHOLD=80

# Default Settings
YOUTUBE_DEFAULT_PRIVACY=private
YOUTUBE_DEFAULT_CATEGORY=22
YOUTUBE_AUTO_UPLOAD_PLAYLIST=
