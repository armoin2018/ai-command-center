# Threads API Configuration
# Get these from: https://developers.facebook.com/

# Meta App Credentials
THREADS_APP_ID=your_app_id_here
THREADS_APP_SECRET=your_app_secret_here

# OAuth Tokens
THREADS_ACCESS_TOKEN=your_access_token_here
THREADS_USER_ID=your_threads_user_id_here
THREADS_INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here

# Account Settings
THREADS_ACCOUNT_TYPE=auto-detect  # or: personal, creator, business

# Rate Limiting
THREADS_RATE_LIMIT_BUFFER=10  # Keep 10 requests in reserve
THREADS_AUTO_RETRY=true
THREADS_MAX_RETRIES=3

# Default Post Settings
THREADS_DEFAULT_VISIBILITY=public
THREADS_MAX_HASHTAGS=5
THREADS_AUTO_ALT_TEXT=true
