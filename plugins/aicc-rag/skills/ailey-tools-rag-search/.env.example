# ChromaDB Configuration
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_PATH=./chromadb_data

# Embedding Provider (openai, cohere, huggingface)
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
COHERE_API_KEY=
HUGGINGFACE_API_KEY=

# Embedding Model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
COHERE_EMBEDDING_MODEL=embed-english-v3.0
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Google Search API (for grounding)
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
SERPAPI_KEY=

# Search Configuration
DEFAULT_TOP_K=10
DEFAULT_SIMILARITY_THRESHOLD=0.7
MAX_RESULTS=50
ENABLE_RERANKING=true

# Google Grounding Configuration
ENABLE_GOOGLE_GROUNDING=true
GOOGLE_RESULTS_COUNT=5
COMBINE_RAG_WEB_RESULTS=true

# Output Configuration
OUTPUT_FORMAT=json
SAVE_RESULTS=true
RESULTS_DIR=./search_results

# Performance
BATCH_SIZE=100
CACHE_ENABLED=true
CACHE_TTL=3600

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/rag-search.log
