# WooCommerce Store Connection Settings

# Self-Hosted WooCommerce
# Get these from: Store Dashboard > Settings > Advanced > REST API
WOOCOMMERCE_STORE_URL=https://your-store.com
WOOCOMMERCE_API_KEY=ck_live_xxxxxxxxxxxxx
WOOCOMMERCE_API_SECRET=cs_live_xxxxxxxxxxxxx

# WooCommerce.com
# Get these from: https://woocommerce.com/my-account/
WOOCOMMERCE_COM_EMAIL=your-email@example.com
WOOCOMMERCE_COM_PASSWORD=your-password

# Optional: Advanced Settings
WOOCOMMERCE_STORE_TYPE=self-hosted
WOOCOMMERCE_API_VERSION=wc/v3
WOOCOMMERCE_TIMEOUT=30000
WOOCOMMERCE_VERBOSE_LOG=false

# Optional: Feature Toggles
WOOCOMMERCE_ENABLE_PRODUCTS=true
WOOCOMMERCE_ENABLE_ORDERS=true
WOOCOMMERCE_ENABLE_CUSTOMERS=true
WOOCOMMERCE_ENABLE_PAYMENTS=true
WOOCOMMERCE_ENABLE_SHIPPING=true
WOOCOMMERCE_ENABLE_REPORTS=true

# Optional: Cache Settings
WOOCOMMERCE_CACHE_TTL=3600
WOOCOMMERCE_MAX_CACHE_ITEMS=1000
