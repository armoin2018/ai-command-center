# CapCut Integration Settings

# CapCut API Credentials
# Get from: https://developers.capcut.com/
CAPCUT_API_KEY=your_api_key_here
CAPCUT_API_SECRET=your_api_secret_here
CAPCUT_ACCESS_TOKEN=your_access_token_here

# Account Information
CAPCUT_USER_ID=your_user_id
CAPCUT_ACCOUNT_TYPE=free

# Optional: Advanced Settings
CAPCUT_API_VERSION=v1
CAPCUT_TIMEOUT=30000
CAPCUT_VERBOSE_LOG=false

# Optional: Feature Toggles
CAPCUT_ENABLE_PROJECTS=true
CAPCUT_ENABLE_TEMPLATES=true
CAPCUT_ENABLE_EFFECTS=true
CAPCUT_ENABLE_MUSIC=true
CAPCUT_ENABLE_EXPORT=true
CAPCUT_ENABLE_BATCH_PROCESSING=false

# Optional: Cache Settings
CAPCUT_CACHE_TTL=3600
CAPCUT_MAX_CACHE_ITEMS=1000
CAPCUT_STORAGE_PATH=./capcut_cache
