# Twilio Skill Environment Variables
# Copy to .env and fill in your values

# Required — Account SID (always needed)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option A: API Key Auth (recommended for production)
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret_here

# Option B: Auth Token (simpler, for development)
TWILIO_AUTH_TOKEN=your_auth_token_here

# Default sender number (E.164 format)
TWILIO_FROM_NUMBER=+15551234567

# Optional — Messaging Service SID (for intelligent sender selection)
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — Verify Service SID (for phone verification)
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — Webhook URL for status callbacks
# TWILIO_WEBHOOK_URL=https://your-domain.com/webhook

# Optional — Override tier detection (free-trial | pay-as-you-go | production)
# TWILIO_TIER=pay-as-you-go
