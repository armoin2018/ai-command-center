# Meetup OAuth Configuration
# Create OAuth client at: https://www.meetup.com/api/oauth/list/

# OAuth Client Credentials (required)
MEETUP_CLIENT_ID=your_oauth_client_id_here
MEETUP_CLIENT_SECRET=your_oauth_client_secret_here
MEETUP_REDIRECT_URI=http://localhost:3000/callback

# OAuth Tokens (populated after authentication)
MEETUP_ACCESS_TOKEN=
MEETUP_REFRESH_TOKEN=
MEETUP_TOKEN_EXPIRY=

# Default Settings (optional)
MEETUP_DEFAULT_TIMEZONE=America/New_York
MEETUP_AUTO_PUBLISH=false
MEETUP_NOTIFY_ON_RSVP=true
MEETUP_MAX_EVENT_CAPACITY=100

# API Configuration (optional)
MEETUP_API_ENDPOINT=https://api.meetup.com/gql
MEETUP_RATE_LIMIT_PER_MINUTE=30
MEETUP_TIMEOUT_MS=30000

# Logging (optional)
LOG_LEVEL=info
