# Environment variables for catalog management

# Default agentic system (copilot, claude, cursor, windsurf, codex, gemini, custom)
AGENTIC_SYSTEM=copilot

# Git cache directory (default: ~/.vscode/cache)
GIT_CACHE_DIR=~/.vscode/cache

# Maximum retry attempts for git operations
MAX_RETRY_ATTEMPTS=3

# Retry backoff multiplier (seconds)
RETRY_BACKOFF_BASE=2

# Maximum backoff time (seconds)
MAX_BACKOFF_TIME=30

# Enable verbose logging
VERBOSE=false

# Enable dry run mode (no actual file operations)
DRY_RUN=false
