    <a href="#performance">⚡ Performance</a>
    <a href="#code-quality">🔍 Code Quality</a>
    <a href="#documentation">📝 Documentation</a>
    <a href="#issues">🐛 Issues</a>
    <div class="nav-group">Strategy</div>
