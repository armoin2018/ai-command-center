    <a href="#instruction-sets">📖 Instruction Sets</a>
    <a href="#personas">🎭 Personas</a>
    <a href="#skills">⚡ Skills</a>
    <a href="#agents">🤖 Agents</a>
    <a href="#prompts">💬 Prompts</a>
