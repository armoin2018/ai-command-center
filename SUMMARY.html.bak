  </nav>
</aside>

<!-- ═══════════════════════════════════════════════════════════════════════
     MAIN CONTENT
     ═══════════════════════════════════════════════════════════════════════ -->
<main class="main-content">

<!-- ─────────────────────────────────────────────────────────────────────
     1. PROJECT DESCRIPTION
     ───────────────────────────────────────────────────────────────────── -->
<section id="project-description">
  <h2>📋 Project Description</h2>
  <div class="card">
    <div style="display:flex;gap:24px;flex-wrap:wrap;">
      <div style="flex:1;min-width:300px;">
        <h3>AI Command Center</h3>
        <p>A comprehensive VS Code extension for AI-powered development workflows with integrated planning, Jira synchronization, and AI assistant integration via Model Context Protocol (MCP).</p>
        <p>The extension provides a full-stack development command center with hierarchical project planning (Epic → Story → Task), real-time collaboration, 50+ AI-powered skills across 10 categories, and enterprise integrations with Jira, Slack, Teams, SharePoint, and more.</p>
        <table>
          <tr><td><strong>Name</strong></td><td>ai-command-center</td></tr>
          <tr><td><strong>Version</strong></td><td>2.0.12</td></tr>
          <tr><td><strong>License</strong></td><td>MIT</td></tr>
          <tr><td><strong>Publisher</strong></td><td>ai-command-center</td></tr>
          <tr><td><strong>VS Code Engine</strong></td><td>^1.85.0</td></tr>
          <tr><td><strong>Repository</strong></td><td>github.com/armoin2018/ai-command-center</td></tr>
        </table>
      </div>
      <div style="min-width:200px;">
        <h3>Key Features</h3>
        <ul style="list-style:none;padding:0;">
          <li>✅ Hierarchical Planning (Epic/Story/Task)</li>
          <li>✅ Jira Bidirectional Sync</li>
          <li>✅ MCP Server (12 Tools, 8 Prompts)</li>
          <li>✅ 22+ WebView Components</li>
          <li>✅ 90 VS Code Commands</li>
          <li>✅ 57 Configuration Properties</li>
          <li>✅ 50 AI-Powered Skills</li>
          <li>✅ 22 Specialized Agents</li>
          <li>✅ 355 Expert Personas</li>
          <li>✅ 282 Instruction Sets</li>
          <li>✅ Real-Time Collaboration</li>
          <li>✅ Enterprise Integrations</li>
        </ul>
      </div>
    </div>
  </div>
  <div class="card-grid">
    <div class="stat-card"><div class="stat-value" style="color:var(--accent-blue)">82,013</div><div class="stat-label">Lines of TypeScript</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--accent-green)">202</div><div class="stat-label">TypeScript Files</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--accent-purple)">90</div><div class="stat-label">VS Code Commands</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--accent-teal)">50</div><div class="stat-label">AI Skills</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--accent-yellow)">355</div><div class="stat-label">Expert Personas</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--accent-peach)">7</div><div class="stat-label">Dependencies</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--accent-pink)">18,128</div><div class="stat-label">Webview Files</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--accent-mauve)">57</div><div class="stat-label">Config Properties</div></div>
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────
     2. ARCHITECTURE
     ───────────────────────────────────────────────────────────────────── -->
<section id="architecture">
  <h2>🏗️ Architecture</h2>

  <div class="card">
    <h3>System Architecture Diagram</h3>
    <div style="text-align:center;padding:20px;overflow-x:auto;">
      <svg viewBox="0 0 900 620" xmlns="http://www.w3.org/2000/svg" style="max-width:900px;width:100%;">
        <!-- Background -->
        <rect width="900" height="620" rx="12" fill="#1e1e2e"/>

        <!-- VS Code Extension Host -->
        <rect x="20" y="20" width="860" height="90" rx="8" fill="#242438" stroke="#cba6f7" stroke-width="1.5"/>
        <text x="450" y="45" text-anchor="middle" fill="#cba6f7" font-size="14" font-weight="600">VS Code Extension Host</text>
        <rect x="40" y="55" width="100" height="40" rx="6" fill="#2a2a3e" stroke="#45475a"/>
        <text x="90" y="80" text-anchor="middle" fill="#89b4fa" font-size="10">extension.ts</text>
        <rect x="160" y="55" width="100" height="40" rx="6" fill="#2a2a3e" stroke="#45475a"/>
        <text x="210" y="80" text-anchor="middle" fill="#89b4fa" font-size="10">ConfigManager</text>
        <rect x="280" y="55" width="100" height="40" rx="6" fill="#2a2a3e" stroke="#45475a"/>
        <text x="330" y="80" text-anchor="middle" fill="#89b4fa" font-size="10">ErrorHandler</text>
        <rect x="400" y="55" width="100" height="40" rx="6" fill="#2a2a3e" stroke="#45475a"/>
        <text x="450" y="80" text-anchor="middle" fill="#89b4fa" font-size="10">Logger</text>
        <rect x="520" y="55" width="100" height="40" rx="6" fill="#2a2a3e" stroke="#45475a"/>
        <text x="570" y="80" text-anchor="middle" fill="#89b4fa" font-size="10">AgentDetector</text>
        <rect x="640" y="55" width="100" height="40" rx="6" fill="#2a2a3e" stroke="#45475a"/>
        <text x="690" y="80" text-anchor="middle" fill="#89b4fa" font-size="10">AIKitManager</text>
        <rect x="760" y="55" width="100" height="40" rx="6" fill="#2a2a3e" stroke="#45475a"/>
        <text x="810" y="80" text-anchor="middle" fill="#89b4fa" font-size="10">IntakeManager</text>

        <!-- Planning Layer -->
        <rect x="20" y="130" width="420" height="130" rx="8" fill="#242438" stroke="#a6e3a1" stroke-width="1.5"/>
        <text x="230" y="152" text-anchor="middle" fill="#a6e3a1" font-size="13" font-weight="600">Planning System</text>
        <rect x="40" y="162" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="85" y="184" text-anchor="middle" fill="#a6e3a1" font-size="9">PlanningMgr</text>
        <rect x="140" y="162" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="185" y="184" text-anchor="middle" fill="#a6e3a1" font-size="9">WorkspaceMgr</text>
        <rect x="240" y="162" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="285" y="184" text-anchor="middle" fill="#a6e3a1" font-size="9">EpicManager</text>
        <rect x="340" y="162" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="385" y="184" text-anchor="middle" fill="#a6e3a1" font-size="9">Validators</text>
        <rect x="40" y="205" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="85" y="227" text-anchor="middle" fill="#a6e3a1" font-size="9">StoryManager</text>
        <rect x="140" y="205" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="185" y="227" text-anchor="middle" fill="#a6e3a1" font-size="9">TaskManager</text>
        <rect x="240" y="205" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="285" y="227" text-anchor="middle" fill="#a6e3a1" font-size="9">TreeBuilder</text>
        <rect x="340" y="205" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="385" y="227" text-anchor="middle" fill="#a6e3a1" font-size="9">Evolution</text>

        <!-- MCP Server Layer -->
        <rect x="460" y="130" width="420" height="130" rx="8" fill="#242438" stroke="#89b4fa" stroke-width="1.5"/>
        <text x="670" y="152" text-anchor="middle" fill="#89b4fa" font-size="13" font-weight="600">MCP Server</text>
        <rect x="480" y="162" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="525" y="184" text-anchor="middle" fill="#89b4fa" font-size="9">MCPManager</text>
        <rect x="580" y="162" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="625" y="184" text-anchor="middle" fill="#89b4fa" font-size="9">MCPServer</text>
        <rect x="680" y="162" width="90" height="35" rx="5" fill="#2a2a3e" stroke="#45475a"/>
        <text x="725" y="184" text-anchor="middle" fill="#89b4fa" font-size="9">HTTP Transport</text>
