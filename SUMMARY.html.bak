<!-- ─────────────────────────────────────────────────────────────────────
     9. AI COMMAND CENTER FEATURES
     ───────────────────────────────────────────────────────────────────── -->
<section id="ai-command-center">
  <h2>🎯 AI Command Center — Feature Overview</h2>
  <div class="card">
    <div class="tab-container">
      <div class="tab-buttons">
        <button class="tab-btn active" onclick="switchTab(this,'tab-planning')">Planning</button>
        <button class="tab-btn" onclick="switchTab(this,'tab-mcp')">MCP Server</button>
        <button class="tab-btn" onclick="switchTab(this,'tab-integrations')">Integrations</button>
        <button class="tab-btn" onclick="switchTab(this,'tab-webview')">WebView UI</button>
        <button class="tab-btn" onclick="switchTab(this,'tab-config')">Configuration</button>
      </div>
      <div id="tab-planning" class="tab-panel active">
        <h4>Planning Management — 90 Commands</h4>
        <ul>
          <li><strong>Hierarchical Structure</strong>: Epic → Story → Task with parent relationships</li>
          <li><strong>Evolution Tracking</strong>: Complete audit trail with version history & MD5 checksums</li>
          <li><strong>Tree Visualization</strong>: Planning tree with traversal utilities</li>
          <li><strong>Advanced Filtering</strong>: Search by status, priority, assignee, story points</li>
          <li><strong>Templates</strong>: Reusable planning templates for common patterns</li>
          <li><strong>Export</strong>: JSON, YAML, Markdown, CSV formats</li>
        </ul>
      </div>
      <div id="tab-mcp" class="tab-panel">
        <h4>Model Context Protocol Server</h4>
        <ul>
          <li><strong>12 MCP Tools</strong>: Create, update, search, bulk ops, statistics</li>
          <li><strong>3 Resources</strong>: Planning tree, epics list, epic details</li>
          <li><strong>8 Prompts</strong>: Epic creation, sprint planning, progress reports</li>
          <li><strong>Transports</strong>: stdio (local) and HTTP (remote) with WebSocket</li>
          <li><strong>Security</strong>: Token-based auth, rate limiting, SSL/TLS</li>
          <li><strong>Leader Election</strong>: Multi-workspace coordination</li>
          <li><strong>Swagger/OpenAPI</strong>: Interactive API documentation</li>
        </ul>
      </div>
      <div id="tab-integrations" class="tab-panel">
        <h4>Enterprise Integrations</h4>
